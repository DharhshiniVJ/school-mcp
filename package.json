{
  "name": "school-mcp-root",
  "version": "1.0.0",
  "description": "School Management System Backend with local Ollama LLM & MCP Architecture",
  "type": "module",
  "scripts": {
    "build:server": "tsc -p server/tsconfig.json",
    "start:mcp": "node server/dist/server.js",
    "start:gateway": "node server/dist/gateway.js",
    "dev:server": "tsc -p server/tsconfig.json -w",
    "dev:gateway": "node --watch --experimental-specifier-resolution=node server/dist/gateway.js",
    "seed": "node --experimental-specifier-resolution=node server/dist/scripts/seed.js",
    "verify": "node --experimental-specifier-resolution=node server/dist/scripts/verify-env.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.5.0",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
